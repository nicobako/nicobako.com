---
import Layout from "../../layouts/Layout.astro";
import { PASSAGES } from "../../printables/speed-reading/passages.ts";
import {
  DEFAULT_OPTIONS,
  describeSheet,
  estimateWidth,
  renderSheetHTML,
} from "../../printables/speed-reading/speed-reading.ts";

// The server has no font metrics, so the first paint is wrapped with an estimate at the
// nominal 96dpi. The browser re-wraps with real measurements the moment it loads.
const measure = estimateWidth(DEFAULT_OPTIONS.fontSizePt);
const pxPerMm = 96 / 25.4;
---

<Layout
  title="Speed Reading Practice — Nico Bako"
  description="A printable practice sheet for reading several words at a single glance, in the style of Triple Your Reading Speed."
>
  <div class="controls no-print">
    <h1>Speed Reading Practice</h1>
    <p>
      Words are set in narrow columns, a few to a line. Fix your eyes on the centre of
      a line, take the whole group in at one glance without moving them, then drop
      straight down to the next line. Never track across.
    </p>
    <p>
      The column width is the span you are training: words fill a line until the next one
      would not fit, so the column - not a word count - decides how much you take in at
      a glance. Start narrow, and widen it only once a width feels effortless.
    </p>
    <p>
      Reading <em>down each column</em> drills the vertical drop the method is built on.
      Reading <em>across, then down</em> lays the text out so the next group sits in the
      next column along, drilling the sideways hop from one fixation to the next instead.
    </p>

    <div class="grid">
      <label>
        <span>Text</span>
        <select id="source">
          <option value="random" selected>Random words</option>
          {
            PASSAGES.map((p) => (
              <option value={p.id}>
                {p.title} — {p.author}
              </option>
            ))
          }
        </select>
      </label>

      <label>
        <span>Columns <output id="cols-out">{DEFAULT_OPTIONS.columns}</output></span>
        <input id="columns" type="range" min="1" max="3" step="1" value={DEFAULT_OPTIONS.columns} />
      </label>

      <label>
        <span>Column width <output id="colw-out">{DEFAULT_OPTIONS.columnWidthMm}mm</output></span>
        <input id="column-width" type="range" min="30" max="90" step="1" value={DEFAULT_OPTIONS.columnWidthMm} />
      </label>

      <label>
        <span>Eye movement</span>
        <select id="flow">
          <option value="down" selected>Down each column</option>
          <option value="across">Across, then down</option>
        </select>
      </label>

      <label>
        <span>Font size <output id="font-out">{DEFAULT_OPTIONS.fontSizePt}pt</output></span>
        <input id="font-size" type="range" min="9" max="22" step="1" value={DEFAULT_OPTIONS.fontSizePt} />
      </label>

      <label>
        <span>Line spacing <output id="spacing-out">{DEFAULT_OPTIONS.lineSpacing}</output></span>
        <input id="line-spacing" type="range" min="1.2" max="3.2" step="0.1" value={DEFAULT_OPTIONS.lineSpacing} />
      </label>

      <label>
        <span>Page size</span>
        <select id="page-size">
          <option value="a4" selected>A4</option>
          <option value="letter">Letter</option>
        </select>
      </label>

      <label>
        <span>Orientation</span>
        <select id="orientation">
          <option value="portrait" selected>Portrait</option>
          <option value="landscape">Landscape</option>
        </select>
      </label>
    </div>

    <div class="actions">
      <label class="check">
        <input id="guide" type="checkbox" checked={DEFAULT_OPTIONS.guide} />
        <span>Centre fixation guide</span>
      </label>
      <button type="button" id="reroll" hidden>Re-roll words</button>
      <button type="button" id="focus" class="primary">Practise</button>
      <button type="button" id="print">Print</button>
    </div>

    <p class="summary" id="summary">{describeSheet(DEFAULT_OPTIONS, measure, pxPerMm)}</p>
    <p class="warning" id="warning" hidden></p>
  </div>

  <div class="sheet-wrap">
    <div id="sheet" set:html={renderSheetHTML(DEFAULT_OPTIONS, measure, pxPerMm)} />
  </div>

  <button type="button" id="exit-focus" class="exit-focus no-print" hidden>Done</button>
</Layout>

<script>
  import {
    describeSheet,
    renderSheetHTML,
    type Flow,
    type Orientation,
    type PageSize,
    type SheetOptions,
  } from "../../printables/speed-reading/speed-reading.ts";

  const sheet = document.getElementById("sheet") as HTMLDivElement;
  const summary = document.getElementById("summary") as HTMLParagraphElement;
  const warning = document.getElementById("warning") as HTMLParagraphElement;
  const reroll = document.getElementById("reroll") as HTMLButtonElement;

  const source = document.getElementById("source") as HTMLSelectElement;
  const columns = document.getElementById("columns") as HTMLInputElement;
  const flow = document.getElementById("flow") as HTMLSelectElement;
  const columnWidth = document.getElementById("column-width") as HTMLInputElement;
  const fontSize = document.getElementById("font-size") as HTMLInputElement;
  const lineSpacing = document.getElementById("line-spacing") as HTMLInputElement;
  const pageSize = document.getElementById("page-size") as HTMLSelectElement;
  const orientation = document.getElementById("orientation") as HTMLSelectElement;
  const guide = document.getElementById("guide") as HTMLInputElement;

  const out = {
    cols: document.getElementById("cols-out")!,
    colw: document.getElementById("colw-out")!,
    font: document.getElementById("font-out")!,
    spacing: document.getElementById("spacing-out")!,
  };

  // DEFAULT_OPTIONS.seed is fixed so the server render is deterministic; if the browser
  // kept it, every visit would open on the same words. Re-seed on load, and let the
  // re-roll button take it from there.
  let seed = Math.floor(Math.random() * 1_000_000) + 1;

  // `@page` lives outside the cascade, so the paper size cannot be driven by a CSS
  // custom property or a scoped rule - the only way to change it is to rewrite the
  // rule itself, which is what this stylesheet is for.
  const pageRule = document.createElement("style");
  document.head.appendChild(pageRule);

  /**
   * Millimetres are a print unit; the browser decides what they are worth on screen.
   * Rather than assume the nominal 96dpi, ask it.
   */
  function pxPerMm(): number {
    const probe = document.createElement("div");
    probe.style.cssText = "position:absolute;visibility:hidden;width:100mm";
    document.body.appendChild(probe);
    const px = probe.getBoundingClientRect().width / 100;
    probe.remove();
    return px;
  }

  // A canvas measures text without touching layout, so the sheet is wrapped and
  // rendered exactly once per change - no measure-then-reflow pass.
  const canvas = document.createElement("canvas");
  const ctx = canvas.getContext("2d")!;

  /**
   * The measurer must use the same face and size the sheet is actually set in, or the
   * lines will be packed to the wrong width.
   */
  function measurerFor(fontSizePt: number) {
    const px = fontSizePt * (96 / 72);
    ctx.font = `${px}px ${getComputedStyle(document.body).fontFamily}`;
    return (line: string) => ctx.measureText(line).width;
  }

  function readOptions(): SheetOptions {
    return {
      source: source.value,
      columns: Number(columns.value),
      flow: flow.value as Flow,
      columnWidthMm: Number(columnWidth.value),
      fontSizePt: Number(fontSize.value),
      lineSpacing: Number(lineSpacing.value),
      guide: guide.checked,
      pageSize: pageSize.value as PageSize,
      orientation: orientation.value as Orientation,
      seed,
    };
  }

  /** Gap between columns; must match the `gap` on `.sr-page`. */
  const COLUMN_GAP_MM = 8;

  /**
   * How many columns actually fit the screen at the chosen width.
   *
   * The column width is the span being trained, so it is never squeezed to make a column
   * count fit - the count gives way instead. A phone gets one column of the same width a
   * desktop shows three of, and the drill is identical.
   */
  function columnsThatFit(opts: SheetOptions, mm: number): number {
    const available = sheet.clientWidth;
    const columnPx = (opts.columnWidthMm + COLUMN_GAP_MM) * mm;
    const fits = Math.floor((available + COLUMN_GAP_MM * mm) / columnPx);
    return Math.max(1, Math.min(opts.columns, fits));
  }

  /**
   * Lines that fit down one column of the *viewport*.
   *
   * A screenful, not a sheet of A4, is the unit that matters here: it is what lets the
   * reader work down a column and reach the next block by scrolling once, rather than
   * scrolling back up to find where the next column begins.
   */
  function linesThatFit(opts: SheetOptions): number {
    const lineHeightPx = opts.fontSizePt * (96 / 72) * opts.lineSpacing;
    const chrome = document.body.classList.contains("sr-focus") ? 5.5 * 16 : 3 * 16;
    return Math.max(4, Math.floor((window.innerHeight - chrome) / lineHeightPx));
  }

  /**
   * The sheet is laid out for whatever it is about to appear on. Screen is the common
   * case - this page is practised on far more often than it is printed - so paper is
   * treated as an export: the full column count and the paper's own page height only
   * come back for the print render.
   */
  function optionsFor(target: "screen" | "print", mm: number): SheetOptions {
    const opts = readOptions();
    if (target === "print") return opts;

    return {
      ...opts,
      columns: columnsThatFit(opts, mm),
      columnLines: linesThatFit(opts),
    };
  }

  function render(target: "screen" | "print" = "screen") {
    const base = readOptions();
    const measure = measurerFor(base.fontSizePt);
    const mm = pxPerMm();
    const opts = optionsFor(target, mm);

    sheet.innerHTML = renderSheetHTML(opts, measure, mm);
    pageRule.textContent = `@page { size: ${base.pageSize} ${base.orientation}; margin: 15mm; }`;

    if (target === "screen") {
      summary.textContent = describeSheet(opts, measure, mm);
      out.cols.textContent = String(base.columns);
      out.colw.textContent = `${base.columnWidthMm}mm`;
      out.font.textContent = `${base.fontSizePt}pt`;
      out.spacing.textContent = base.lineSpacing.toFixed(1);

      // With a single column there is nowhere to hop sideways to, so the choice is moot.
      flow.disabled = base.columns === 1;
      reroll.hidden = base.source !== "random";

      checkFit(base, opts);
    }
  }

  /**
   * Two things the reader needs telling, neither of which is an error: the screen is too
   * narrow to show every column they asked for (the print will still have them all), or
   * a single word is too long for the column, which no amount of packing can fix.
   */
  function checkFit(requested: SheetOptions, shown: SheetOptions) {
    const page = sheet.querySelector<HTMLElement>(".sr-page");
    if (!page) return;

    const wordTooWide = [...page.querySelectorAll<HTMLElement>(".sr-col")].some(
      (col) => col.scrollWidth - col.clientWidth > 1,
    );
    const droppedColumns = shown.columns < requested.columns;

    if (wordTooWide) {
      warning.textContent =
        "Some words are too long for this column on their own. Widen the column, or reduce the font size.";
    } else if (droppedColumns) {
      const shownText = shown.columns === 1 ? "one column" : `${shown.columns} columns`;
      warning.textContent = `This screen only fits ${shownText} at ${requested.columnWidthMm}mm, so that is what is shown. Printing still uses all ${requested.columns}.`;
    }
    warning.hidden = !wordTooWide && !droppedColumns;
  }

  for (const control of [
    source,
    columns,
    flow,
    columnWidth,
    fontSize,
    lineSpacing,
    pageSize,
    orientation,
    guide,
  ]) {
    control.addEventListener("input", () => render());
  }

  // Web fonts land after first paint and change every text width, so re-wrap once the
  // real face is in.
  document.fonts?.ready.then(() => render());

  // Both how many columns fit and how many lines make a screenful are viewport
  // measurements, so they have to be taken again whenever the viewport changes -
  // rotating a phone, or entering focus mode.
  let resizeTimer = 0;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => render(), 150);
  });

  reroll.addEventListener("click", () => {
    seed = Math.floor(Math.random() * 1_000_000) + 1;
    render();
  });

  // The screen render shows only the columns that fit and paginates by viewport, so the
  // sheet has to be rebuilt to paper's terms for the print, then handed back.
  window.addEventListener("beforeprint", () => render("print"));
  window.addEventListener("afterprint", () => render("screen"));

  document.getElementById("print")!.addEventListener("click", () => window.print());

  const exitFocus = document.getElementById("exit-focus") as HTMLButtonElement;

  function setFocus(on: boolean) {
    document.body.classList.toggle("sr-focus", on);
    exitFocus.hidden = !on;
    // The viewport just grew (or shrank) by the height of the controls, so the number of
    // lines in a screenful has changed.
    render();
    if (on) window.scrollTo({ top: 0 });
  }

  document.getElementById("focus")!.addEventListener("click", () => setFocus(true));
  exitFocus.addEventListener("click", () => setFocus(false));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && document.body.classList.contains("sr-focus")) setFocus(false);
  });

  render();
</script>

<style>
  .controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.9rem 1.25rem;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  label > span {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  output {
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  select {
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--text);
  }

  input[type="range"] {
    accent-color: var(--accent);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .check {
    flex-direction: row;
    align-items: center;
    gap: 0.4rem;
  }

  .check span {
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.9rem;
    color: var(--text);
  }

  .check input {
    accent-color: var(--accent);
  }

  button {
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
  }

  button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  button.primary {
    margin-left: auto;
    border-color: var(--accent);
    background: transparent;
    color: var(--accent);
    font-weight: 600;
  }

  button.primary:hover {
    background: var(--accent);
    color: var(--accent-text);
  }

  .summary {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .warning {
    margin: 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
    background: var(--surface);
    font-size: 0.9rem;
    color: var(--text);
  }

  /* This page is practised on far more often than it is printed, so the screen layout is
     the real one: no simulated sheet of A4, no page margins, nothing to scroll sideways.
     The script renders only as many columns as the viewport can hold, and rebuilds the
     sheet to paper's terms only when the print dialog opens. */
  .sheet-wrap :global(.sr-page) {
    display: flex;
    justify-content: center;
    gap: 8mm;
    margin: 0 auto 2.5rem;
  }

  /* The column is a hard frame: it is the span being trained, so it never stretches or
     shrinks to fit the layout. Words are packed to it instead, and a group never wraps -
     a group split over two lines is two glances, not one. */
  .sheet-wrap :global(.sr-col) {
    position: relative;
    width: var(--sr-col-width);
    max-width: 100%;
    flex: 0 0 auto;
  }

  /* The fixation guide is a rule rather than a tinted background: browsers drop
     background colours from printouts by default, but they always print borders. */
  .sheet-wrap :global(.sr-has-guide .sr-col::before) {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    border-left: 1px dashed var(--border);
  }

  .sheet-wrap :global(.sr-line) {
    margin: 0;
    text-align: center;
    font-size: var(--sr-font-size);
    line-height: var(--sr-line-spacing);
    white-space: nowrap;
  }

  /* Focus mode: the words, and nothing else. Practice is the main use of this page, so
     it gets the whole viewport - site chrome, controls and all - back on Esc. */
  .exit-focus {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 2;
  }

  :global(body.sr-focus) .controls {
    display: none;
  }

  /* The header and footer belong to the layout, so reaching them means leaving this
     component's scope. */
  :global(body.sr-focus .site-header),
  :global(body.sr-focus footer) {
    display: none;
  }

  /* Top padding clears the fixed Done button, which would otherwise sit on the first
     line of the first column. Keep it in step with the chrome allowance in
     linesThatFit(). */
  :global(body.sr-focus main) {
    max-width: none;
    padding: 3.5rem 1rem 1rem;
  }

  @media print {
    .exit-focus {
      display: none;
    }

    /* On paper the `@page` box supplies the sheet and its margins; each block of columns
       is one sheet. */
    .sheet-wrap :global(.sr-page) {
      gap: 10mm;
      margin: 0;
      break-after: page;
    }

    .sheet-wrap :global(.sr-page:last-child) {
      break-after: auto;
    }

    /* --border is a near-white token; on paper the guide needs an ink value. */
    .sheet-wrap :global(.sr-has-guide .sr-col::before) {
      border-left-color: #c9c9c9;
    }

    .sheet-wrap :global(.sr-line) {
      color: #000;
    }
  }
</style>

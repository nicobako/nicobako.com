---
import Layout from "../../layouts/Layout.astro";

const controls = [
  {
    keys: "Arrow keys / WASD",
    action: "Move around the school one square at a time.",
  },
  {
    keys: "Space / F",
    action: "Fight an adjacent teacher — or stun a hall monitor to slip past.",
  },
  { keys: "R", action: "Restart after a win or a loss." },
];

const tips = [
  "Walk over the coloured tiles in the classrooms and hallways to pick up tools (rulers, slingshots, paper planes…). Each one adds attack power; the apple heals you.",
  "Stand next to an angry teacher and attack. You win the fight if your attack power is at least the teacher’s strength — otherwise go find more tools.",
  "Enemies flash red when they hit you, and each hit costs a heart. Lose all five hearts and it’s detention.",
  "Clear all three levels: teachers stand still, then roam the halls, then roam alongside purple hall monitors you can only stun, never beat.",
];
---

<Layout
  title="Classrooms & Angry Teachers — a game by Nico Bako"
  description="A small 2D browser game built with Kaplay and TypeScript: grab tools, fight angry teachers, and clear the school across three levels."
>
  <p class="eyebrow"><small>A little game I built</small></p>
  <h1>Classrooms &amp; Angry Teachers</h1>
  <p class="lede">
    A 2D browser game built with <a
      href="https://kaplayjs.com/"
      target="_blank"
      rel="noopener noreferrer">Kaplay</a
    >, TypeScript. Grab tools, fight your way past the angry teachers, replenish
    your strength with apples, and clear the school across three levels. Click
    the board, then use the keyboard to play.
  </p>

  <div class="stage">
    <div
      id="game-root"
      role="application"
      aria-label="Classrooms and Angry Teachers game board"
    >
    </div>
  </div>

  <section aria-label="How to play">
    <h2>How to play</h2>
    <ul class="controls">
      {
        controls.map((c) => (
          <li>
            <kbd>{c.keys}</kbd>
            <span>{c.action}</span>
          </li>
        ))
      }
    </ul>
    <ul class="tips">
      {tips.map((tip) => <li>{tip}</li>)}
    </ul>
  </section>
</Layout>

<script>
  // Side-effect import: starts Kaplay and mounts the canvas into #game-root.
  import "../../games/classrooms-and-angry-teachers/game.ts";
</script>

<style>
  .eyebrow {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .lede {
    color: var(--muted);
  }

  /* Game board: Kaplay mounts its canvas into #game-root and sizes it to this
	   element, letterboxing the 640x700 world to fit. The aspect-ratio keeps the
	   frame matched so there are no black bars. */
  .stage {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  #game-root {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 640 / 700;
    border-radius: 10px;
    overflow: hidden;
    background: #10121e;
    border: 1px solid var(--border);
  }

  #game-root :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .controls {
    list-style: none;
    display: grid;
    gap: 0.6rem;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .controls li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    margin-top: 0;
    font-size: 0.95rem;
    color: var(--muted);
  }

  .controls kbd {
    flex: none;
    min-width: 150px;
  }

  .tips {
    color: var(--muted);
    font-size: 0.95rem;
  }

  @media (max-width: 560px) {
    kbd {
      min-width: 0;
    }
  }
</style>

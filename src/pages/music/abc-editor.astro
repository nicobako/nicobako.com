---
import Layout from "../../layouts/Layout.astro";

const defaultTune = `X:1
T:Twinkle, Twinkle, Little Star
M:4/4
L:1/4
K:C
C C G G | A A G2 | F F E E | D D C2 |
G G F F | E E D2 | G G F F | E E D2 |
C C G G | A A G2 | F F E E | D D C2 |]
`;
---

<Layout
  title="ABC Editor — Nico Bako"
  description="Write ABC music notation and see it rendered live, with playback."
>
  <h1 class="no-print">ABC Editor</h1>
  <p class="no-print">
    Write tunes in <a href="https://abcnotation.com/wiki/abc:standard:v2.1" target="_blank" rel="noopener">ABC notation</a>.
    Each <code>X:</code> header starts a new track — separate tunes with a blank
    line and every one gets its own sheet music, player, and downloads below.
    This page's URL updates as you type too — copy it to share or bookmark the
    current tune.
  </p>

  <div class="abc-editor">
    <div class="abc-tunes no-print">
      <label for="tune-select">Tune</label>
      <select id="tune-select" aria-label="Select tune to edit"></select>
      <button id="new-tune-btn" type="button">New</button>
      <button id="rename-tune-btn" type="button">Rename</button>
      <button id="duplicate-tune-btn" type="button">Duplicate</button>
      <button id="delete-tune-btn" type="button">Delete</button>
    </div>

    <textarea
      id="abc-input"
      class="abc-input no-print"
      spellcheck="false"
      aria-label="ABC notation source"
    >{defaultTune}</textarea>

    <div class="abc-controls no-print">
      <button id="upload-abc-btn" type="button">Upload .abc</button>
      <input id="upload-abc-input" class="visually-hidden" type="file" accept=".abc,text/plain" />
      <button id="print-btn" type="button">Print</button>
    </div>

    <p id="upload-status" class="abc-download-status no-print" aria-live="polite"></p>

    <div id="abc-tracks" class="abc-tracks"></div>
  </div>

  <template id="track-template">
    <section class="abc-track">
      <div class="abc-notation-wrap">
        <div class="abc-notation" data-notation></div>
      </div>
      <div class="abc-warnings no-print" data-warnings aria-live="polite"></div>
      <div class="abc-audio no-print" data-audio></div>
      <div class="abc-controls no-print">
        <button type="button" data-download-abc>Download .abc</button>
        <button type="button" data-download-wav>Download WAV</button>
        <button type="button" data-download-midi>Download MIDI</button>
      </div>
      <p class="abc-download-status no-print" data-status aria-live="polite"></p>
    </section>
  </template>
</Layout>

<script>
  import { AbcEditor } from "../../music/abc-editor/abc-editor.ts";
  import {
    loadStore,
    saveStore,
    getActive,
    createTune,
    duplicateTune,
    renameTune,
    deleteTune,
    setActive,
  } from "../../music/abc-editor/persistence.ts";

  const input = document.getElementById("abc-input") as HTMLTextAreaElement;
  const tracks = document.getElementById("abc-tracks")!;
  const trackTemplate = document.getElementById("track-template") as HTMLTemplateElement;
  const uploadStatus = document.getElementById("upload-status")!;
  const tuneSelect = document.getElementById("tune-select") as HTMLSelectElement;

  // The textarea's initial value is the Twinkle default from the frontmatter; it
  // seeds the store on first visit and every freshly created tune.
  const seedAbc = input.value;
  let store = loadStore(seedAbc);

  const editor = new AbcEditor({ container: tracks, template: trackTemplate });

  function renderTuneSelect(): void {
    tuneSelect.innerHTML = "";
    for (const tune of store.tunes) {
      const option = document.createElement("option");
      option.value = tune.id;
      option.textContent = tune.name;
      if (tune.id === store.activeId) option.selected = true;
      tuneSelect.appendChild(option);
    }
  }

  function loadActiveIntoEditor(): void {
    input.value = getActive(store).abc;
    editor.render(input.value);
    renderTuneSelect();
  }

  loadActiveIntoEditor();

  input.addEventListener("input", () => {
    getActive(store).abc = input.value;
    editor.render(input.value);
    saveStore(store);
  });

  tuneSelect.addEventListener("change", () => {
    setActive(store, tuneSelect.value);
    saveStore(store);
    loadActiveIntoEditor();
  });

  document.getElementById("new-tune-btn")!.addEventListener("click", () => {
    createTune(store, "New tune", seedAbc);
    saveStore(store);
    loadActiveIntoEditor();
  });

  document.getElementById("duplicate-tune-btn")!.addEventListener("click", () => {
    duplicateTune(store);
    saveStore(store);
    loadActiveIntoEditor();
  });

  document.getElementById("rename-tune-btn")!.addEventListener("click", () => {
    const name = window.prompt("Tune name", getActive(store).name)?.trim();
    if (!name) return;
    renameTune(store, name);
    saveStore(store);
    renderTuneSelect();
  });

  document.getElementById("delete-tune-btn")!.addEventListener("click", () => {
    if (!window.confirm(`Delete "${getActive(store).name}"?`)) return;
    deleteTune(store, seedAbc);
    saveStore(store);
    loadActiveIntoEditor();
  });

  const uploadInput = document.getElementById("upload-abc-input") as HTMLInputElement;

  document.getElementById("upload-abc-btn")!.addEventListener("click", () => {
    uploadInput.click();
  });

  uploadInput.addEventListener("change", () => {
    const file = uploadInput.files?.[0];
    if (!file) return;

    file
      .text()
      .then((text) => {
        input.value = text;
        getActive(store).abc = text;
        editor.render(text);
        saveStore(store);
        uploadStatus.textContent = "";
      })
      .catch(() => {
        uploadStatus.textContent = "Couldn't read that file.";
      })
      .finally(() => {
        uploadInput.value = "";
      });
  });

  document.getElementById("print-btn")!.addEventListener("click", () => {
    window.print();
  });
</script>

<style>
  .abc-editor {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .abc-input {
    width: 100%;
    min-height: 14rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.5;
    resize: vertical;
  }

  .abc-warnings {
    min-height: 1.2em;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #c0392b;
    white-space: pre-wrap;
  }

  @media (prefers-color-scheme: dark) {
    .abc-warnings {
      color: #ff8a80;
    }
  }

  .abc-tracks {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .abc-track {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .abc-track + .abc-track {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .abc-notation-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    padding: 0.5rem 0.75rem;
  }

  .abc-notation {
    color: var(--text);
    min-width: max-content;
  }

  .abc-audio {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .abc-tunes {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
  }

  .abc-tunes label {
    font-size: 0.9rem;
    color: var(--muted);
  }

  .abc-tunes select {
    padding: 0.5rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    font-size: 0.9rem;
    cursor: pointer;
  }

  .abc-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .abc-tunes button,
  .abc-controls button {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    font-size: 0.9rem;
    cursor: pointer;
  }

  .abc-tunes button:hover,
  .abc-controls button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .abc-download-status {
    min-height: 1.2em;
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  @media print {
    .abc-notation-wrap {
      border: none;
      padding: 0;
      overflow: visible;
    }

    .abc-track + .abc-track {
      padding-top: 0;
      border-top: none;
    }
  }
</style>

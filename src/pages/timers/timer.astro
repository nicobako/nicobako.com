---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Timer — Nico Bako"
  description="A simple browser countdown timer."
>
  <h1>Timer</h1>

  <div class="timer">
    <div id="display" class="display" aria-live="polite">05:00</div>

    <div id="duration-row" class="duration-row">
      <label>
        <span>Min</span>
        <input id="minutes" type="number" min="0" max="180" value="5" />
      </label>
      <label>
        <span>Sec</span>
        <input id="seconds" type="number" min="0" max="59" value="0" />
      </label>
    </div>

    <div class="presets">
      <button data-minutes="1">1m</button>
      <button data-minutes="5">5m</button>
      <button data-minutes="10">10m</button>
      <button data-minutes="20">20m</button>
      <button data-minutes="30">30m</button>
    </div>

    <div class="controls">
      <button id="start-pause" class="primary">Start</button>
      <button id="reset">Reset</button>
    </div>

    <p id="status" class="status" role="status"></p>
  </div>
</Layout>

<script>
  import { Countdown, formatClock } from "../../timers/shared/countdown.ts";
  import { playAlarm } from "../../timers/shared/audio.ts";

  type State = "idle" | "running" | "paused" | "done";

  const display = document.getElementById("display")!;
  const minutesInput = document.getElementById("minutes") as HTMLInputElement;
  const secondsInput = document.getElementById("seconds") as HTMLInputElement;
  const durationRow = document.getElementById("duration-row")!;
  const startPauseBtn = document.getElementById("start-pause") as HTMLButtonElement;
  const resetBtn = document.getElementById("reset") as HTMLButtonElement;
  const statusEl = document.getElementById("status")!;
  const presetButtons = document.querySelectorAll<HTMLButtonElement>(".presets button");

  let state: State = "idle";

  function inputDurationMs(): number {
    const m = Math.max(0, Number(minutesInput.value) || 0);
    const s = Math.max(0, Math.min(59, Number(secondsInput.value) || 0));
    return (m * 60 + s) * 1000;
  }

  function syncIdleDisplay(): void {
    if (state === "idle") {
      display.textContent = formatClock(inputDurationMs());
    }
  }

  function setState(next: State): void {
    state = next;
    display.classList.toggle("done", next === "done");
    statusEl.textContent = next === "done" ? "Time's up!" : "";

    const locked = next === "running" || next === "paused";
    minutesInput.disabled = locked;
    secondsInput.disabled = locked;
    durationRow.classList.toggle("disabled", locked);

    startPauseBtn.textContent = next === "running" ? "Pause" : next === "paused" ? "Resume" : "Start";
  }

  const countdown = new Countdown(
    ({ remainingMs }) => {
      display.textContent = formatClock(remainingMs);
    },
    () => {
      display.textContent = "00:00";
      playAlarm();
      setState("done");
    },
  );

  syncIdleDisplay();
  minutesInput.addEventListener("input", syncIdleDisplay);
  secondsInput.addEventListener("input", syncIdleDisplay);

  presetButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      if (state === "running" || state === "paused") return;
      minutesInput.value = btn.dataset.minutes!;
      secondsInput.value = "0";
      syncIdleDisplay();
    });
  });

  startPauseBtn.addEventListener("click", () => {
    if (state === "running") {
      countdown.pause();
      setState("paused");
      return;
    }
    if (state === "paused") {
      countdown.resume();
      setState("running");
      return;
    }
    const durationMs = inputDurationMs();
    if (durationMs <= 0) return;
    countdown.start(durationMs);
    setState("running");
  });

  resetBtn.addEventListener("click", () => {
    countdown.reset();
    setState("idle");
    syncIdleDisplay();
  });
</script>

<style>
  .timer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .display {
    font-family: var(--font-mono);
    font-size: clamp(3rem, 12vw, 5rem);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--text);
  }

  .display.done {
    color: var(--accent);
  }

  .duration-row {
    display: flex;
    gap: 1.25rem;
  }

  .duration-row.disabled {
    opacity: 0.5;
  }

  .duration-row label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .duration-row input {
    width: 4.5rem;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--text);
    padding: 0.35rem 0.5rem;
    -moz-appearance: textfield;
  }

  .duration-row input::-webkit-outer-spin-button,
  .duration-row input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  .presets {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .presets button {
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--text);
    font-size: 0.85rem;
    cursor: pointer;
  }

  .presets button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .controls {
    display: flex;
    gap: 0.75rem;
  }

  .controls button {
    min-width: 7rem;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
  }

  .controls button.primary {
    border-color: var(--accent);
    background: transparent;
    color: var(--accent);
    transition:
      background 0.12s,
      color 0.12s;
  }

  .controls button.primary:hover {
    background: var(--accent);
    color: var(--accent-text);
  }

  .status {
    min-height: 1.4em;
    font-weight: 600;
    color: var(--accent);
  }
</style>

---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Timers — Nico Bako" description="A collection of browser timers.">
  <h1>Timers</h1>
  <p>A small collection of timers for focus, workouts, and everything in between.</p>
  <ul>
    <li><a href="/timers/timer">Timer</a> — a simple countdown timer.</li>
    <li>
      <a href="/timers/pomodoro">Pomodoro</a> — configurable focus/break cycles.
    </li>
    <li>
      <a href="/timers/meditation">Meditation</a> — a quiet countdown with optional start,
      interval, and end bells.
    </li>
    <li>
      <a href="/timers/interval">Interval</a> — any number of named intervals, repeated over
      multiple rounds.
    </li>
    <li><a href="/timers/stopwatch">Stopwatch</a> — count up, with lap tracking.</li>
  </ul>
</Layout>

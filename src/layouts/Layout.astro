---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
	title = 'Nico Bako — Software Engineer',
	description = 'Nico Bako is a software engineer who builds clean, reliable software with a focus on the Python ecosystem.',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Nico Bako" />
		<meta name="theme-color" content="#16161a" media="(prefers-color-scheme: dark)" />
		<meta name="theme-color" content="#fdfdfc" media="(prefers-color-scheme: light)" />
		<link rel="canonical" href={canonical} />

		<!-- Open Graph / social -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	/* ------------------------------------------------------------------ *
	 * Design tokens
	 * ------------------------------------------------------------------ */
	:root {
		color-scheme: light dark;

		--font-sans: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial,
			'Apple Color Emoji', 'Segoe UI Emoji', sans-serif;
		--font-mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas,
			'Liberation Mono', monospace;

		--bg: #fdfdfc;
		--text: #1f1f1f;
		--muted: #5e5e5e;
		--border: #e3e2dd;
		--surface: #f4f3ef;
		--accent: #2a5db0;
		--accent-text: #ffffff;

		/* Readable line-length shared by header, main, and footer. */
		--measure: 46rem;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #16161a;
			--text: #e6e6e3;
			--muted: #a0a0a0;
			--border: #2c2c33;
			--surface: #1f1f25;
			--accent: #8fb4ff;
			--accent-text: #16161a;
		}
	}

	/* ------------------------------------------------------------------ *
	 * CSS reset — Josh W. Comeau's Custom CSS Reset
	 * https://www.joshwcomeau.com/css/custom-css-reset/
	 * ------------------------------------------------------------------ */
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	* {
		margin: 0;
	}

	html {
		-moz-text-size-adjust: none;
		-webkit-text-size-adjust: none;
		text-size-adjust: none;
	}

	body {
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}

	img,
	picture,
	video,
	canvas,
	svg {
		display: block;
		max-width: 100%;
	}

	input,
	button,
	textarea,
	select {
		font: inherit;
	}

	p,
	h1,
	h2,
	h3,
	h4,
	h5,
	h6 {
		overflow-wrap: break-word;
	}

	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3,
	h4,
	h5,
	h6 {
		text-wrap: balance;
	}

	/* ------------------------------------------------------------------ *
	 * Semantic element styling
	 * Element selectors only — no classes, no component layout. Components
	 * add their own scoped CSS on top of these defaults.
	 * ------------------------------------------------------------------ */
	body {
		font-family: var(--font-sans);
		font-size: 1.0625rem;
		color: var(--text);
		background: var(--bg);
	}

	main {
		max-width: var(--measure);
		margin: 0 auto;
		padding: 3rem 1.25rem 4rem;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 2.6rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin-bottom: 0.5rem;
	}

	h2 {
		font-size: 1.4rem;
		line-height: 1.25;
		margin-top: 2.75rem;
		margin-bottom: 0.75rem;
	}

	h3 {
		font-size: 1.1rem;
		margin-top: 1.75rem;
		margin-bottom: 0.5rem;
	}

	p {
		margin-bottom: 1rem;
	}

	a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	a:hover {
		text-decoration: none;
	}

	ul,
	ol {
		padding-left: 1.4rem;
		margin-bottom: 1rem;
	}

	li + li {
		margin-top: 0.35rem;
	}

	/* Navigation lists read as rows of links, not bullets. */
	nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	nav li + li {
		margin-top: 0;
	}

	hr {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2.5rem 0;
	}

	code {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--surface);
		border-radius: 4px;
		padding: 0.1em 0.35em;
	}

	kbd {
		font-family: var(--font-mono);
		font-size: 0.85em;
		color: var(--text);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: 0.15em 0.5em;
	}

	small {
		font-size: 0.85rem;
		color: var(--muted);
	}

	:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
		border-radius: 2px;
	}

	/* ------------------------------------------------------------------ *
	 * Print — hide site chrome so printable pages fill the sheet.
	 * Elements opt out of printing with the `.no-print` class.
	 * ------------------------------------------------------------------ */
	@media print {
		.site-header,
		footer,
		.no-print {
			display: none !important;
		}

		main {
			max-width: none;
			margin: 0;
			padding: 0;
		}
	}
</style>

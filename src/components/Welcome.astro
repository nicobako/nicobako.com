---
const year = new Date().getFullYear();

const focus = [
	{
		title: 'Backend & APIs',
		body: 'Designing clean, well-tested services and APIs that are a pleasure to build on and easy to maintain.',
		icon: 'server',
	},
	{
		title: 'The Python Ecosystem',
		body: 'Deep in Python day to day — from typing and tooling to packaging and the libraries that make it shine.',
		icon: 'python',
	},
	{
		title: 'Reliable Software',
		body: 'Favoring simplicity, strong tests, and thoughtful design so software keeps working long after launch.',
		icon: 'shield',
	},
];

const stack = [
	'Python',
	'FastAPI',
	'PostgreSQL',
	'Docker',
	'TypeScript',
	'Astro',
	'Git',
	'Linux',
];
---

<main>
	<div class="backdrop" aria-hidden="true"></div>

	<section class="hero" aria-labelledby="hero-name">
		<div class="hero__intro">
			<span class="badge">
				<span class="badge__dot"></span>
				Open to interesting work
			</span>

			<h1 id="hero-name">
				Hi, I'm <span class="gradient">Nico Bako</span>.
			</h1>

			<p class="role">Software Engineer</p>

			<p class="lede">
				I build clean, reliable software with a penchant for Python. I care about
				thoughtful design, solid tests, and tools that make engineering feel effortless.
			</p>

			<div class="actions">
				<a class="btn btn--primary" href="mailto:nicobako@gmail.com">
					<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path
							fill="none"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M3 6.5A1.5 1.5 0 0 1 4.5 5h15A1.5 1.5 0 0 1 21 6.5v11A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5v-11Z M3.5 6.8l8.5 6 8.5-6"
						></path>
					</svg>
					Get in touch
				</a>
				<a
					class="btn btn--ghost"
					href="https://github.com/nicobako"
					target="_blank"
					rel="noopener noreferrer"
				>
					<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path
							fill="currentColor"
							d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.36 1.11 2.94.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.36 9.36 0 0 1 2.5-.34c.85 0 1.71.12 2.5.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.35 4.79-4.58 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"
						></path>
					</svg>
					GitHub
				</a>
			</div>

			<div class="socials" aria-label="Find me online">
				<a class="social" href="https://github.com/nicobako" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
					<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
						<path
							fill="currentColor"
							d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.36 1.11 2.94.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.36 9.36 0 0 1 2.5-.34c.85 0 1.71.12 2.5.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.35 4.79-4.58 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"
						></path>
					</svg>
				</a>
				<a class="social" href="mailto:nicobako@gmail.com" aria-label="Email">
					<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
						<path
							fill="none"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M3 6.5A1.5 1.5 0 0 1 4.5 5h15A1.5 1.5 0 0 1 21 6.5v11A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5v-11Z M3.5 6.8l8.5 6 8.5-6"
						></path>
					</svg>
				</a>
			</div>
		</div>

		<div class="hero__avatar" aria-hidden="true">
			<div class="avatar-ring">
				<div class="avatar">NB</div>
			</div>
		</div>
	</section>

	<section class="focus" aria-label="What I do">
		{
			focus.map((item) => (
				<article class="card">
					<span class="card__icon">
						{item.icon === 'server' && (
							<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
								<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M4 5.5h16v5H4zM4 13.5h16v5H4zM7.5 8h.01M7.5 16h.01" />
							</svg>
						)}
						{item.icon === 'python' && (
							<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
								<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M9 6.5c0-1.4 1.3-2.5 3-2.5s3 1.1 3 2.5V10H9.5A2.5 2.5 0 0 0 7 12.5v2M15 17.5c0 1.4-1.3 2.5-3 2.5s-3-1.1-3-2.5V14h5.5A2.5 2.5 0 0 0 17 11.5v-2" />
							</svg>
						)}
						{item.icon === 'shield' && (
							<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
								<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M12 3.5 19 6v5c0 4.5-3 7.7-7 9.5-4-1.8-7-5-7-9.5V6l7-2.5ZM9 12l2 2 4-4" />
							</svg>
						)}
					</span>
					<h2>{item.title}</h2>
					<p>{item.body}</p>
				</article>
			))
		}
	</section>

	<section class="stack" aria-label="Tools I work with">
		<p class="stack__label">Tools I reach for</p>
		<ul class="tags">
			{stack.map((tech) => <li class="tag">{tech}</li>)}
		</ul>
	</section>

	<section class="play" aria-label="A game I built">
		<a class="play__card" href="/games/classrooms-and-angry-teachers">
			<span class="play__badge">
				<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
					<path
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M6 12h4m-2-2v4M15 11h.01M18 13h.01M7.5 7h9a4 4 0 0 1 3.95 3.36l.7 4.2A2.5 2.5 0 0 1 18.7 17.4l-1.2-1.6a2 2 0 0 0-1.6-.8H8.1a2 2 0 0 0-1.6.8l-1.2 1.6A2.5 2.5 0 0 1 .85 14.56l.7-4.2A4 4 0 0 1 5.5 7Z"
					></path>
				</svg>
			</span>
			<span class="play__text">
				<span class="play__label">Play my game</span>
				<span class="play__title">Classrooms &amp; Angry Teachers</span>
				<span class="play__desc">A little 2D browser game I built with Kaplay &amp; TypeScript.</span>
			</span>
			<span class="play__arrow" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="20" height="20">
					<path
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M9 5l7 7-7 7"></path>
				</svg>
			</span>
		</a>
	</section>

	<footer class="footer">
		<span>© {year} Nico Bako</span>
		<span class="footer__sep" aria-hidden="true">·</span>
		<span>Built with Astro</span>
	</footer>
</main>

<style>
	main {
		position: relative;
		max-width: 980px;
		margin: 0 auto;
		padding: 72px 24px 48px;
	}

	.backdrop {
		position: fixed;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(60% 50% at 75% 0%, var(--glow), transparent 70%),
			radial-gradient(50% 40% at 0% 10%, var(--glow), transparent 70%);
		pointer-events: none;
	}

	/* Hero */
	.hero {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: 48px;
		padding-bottom: 24px;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 13px;
		font-weight: 500;
		color: var(--text-muted);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 6px 14px;
		box-shadow: var(--shadow);
	}

	.badge__dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #22c55e;
		box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.18);
	}

	h1 {
		font-size: clamp(2.2rem, 6vw, 3.5rem);
		line-height: 1.08;
		font-weight: 800;
		letter-spacing: -0.025em;
		margin: 20px 0 4px;
	}

	.gradient {
		background: linear-gradient(120deg, var(--accent), var(--accent-2));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.role {
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--text-muted);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin: 0 0 16px;
	}

	.lede {
		font-size: 1.125rem;
		color: var(--text-muted);
		max-width: 46ch;
		margin: 0 0 28px;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-bottom: 24px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		padding: 11px 20px;
		border-radius: 12px;
		border: 1px solid transparent;
		transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease,
			border-color 0.15s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn--primary {
		color: var(--accent-contrast);
		background: linear-gradient(120deg, var(--accent), var(--accent-2));
		box-shadow: 0 8px 20px var(--ring);
	}

	.btn--ghost {
		color: var(--text);
		background: var(--surface);
		border-color: var(--border);
		box-shadow: var(--shadow);
	}

	.btn--ghost:hover {
		border-color: var(--accent);
	}

	.socials {
		display: flex;
		gap: 10px;
	}

	.social {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 12px;
		color: var(--text-muted);
		background: var(--surface);
		border: 1px solid var(--border);
		box-shadow: var(--shadow);
		transition: transform 0.15s ease, color 0.15s ease, border-color 0.15s ease;
	}

	.social:hover {
		color: var(--accent);
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	/* Avatar */
	.hero__avatar {
		display: flex;
		justify-content: center;
	}

	.avatar-ring {
		padding: 6px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--accent), var(--accent-2));
		box-shadow: 0 20px 50px var(--ring);
		animation: float 6s ease-in-out infinite;
	}

	.avatar {
		width: 168px;
		height: 168px;
		border-radius: 50%;
		background: var(--surface);
		color: var(--text);
		font-size: 56px;
		font-weight: 800;
		letter-spacing: 0.02em;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	@keyframes float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	/* Focus cards */
	.focus {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
		margin-top: 56px;
	}

	.card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 18px;
		padding: 28px 24px;
		box-shadow: var(--shadow);
		transition: transform 0.18s ease, border-color 0.18s ease;
	}

	.card:hover {
		transform: translateY(-4px);
		border-color: var(--accent);
	}

	.card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 46px;
		height: 46px;
		border-radius: 12px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
		margin-bottom: 16px;
	}

	.card h2 {
		font-size: 1.15rem;
		font-weight: 700;
		margin: 0 0 8px;
	}

	.card p {
		font-size: 0.95rem;
		color: var(--text-muted);
		margin: 0;
	}

	/* Stack */
	.stack {
		margin-top: 56px;
		text-align: center;
	}

	.stack__label {
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 18px;
	}

	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px;
		padding: 0;
		margin: 0;
	}

	.tag {
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--text);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 7px 16px;
		box-shadow: var(--shadow);
		transition: transform 0.15s ease, color 0.15s ease, border-color 0.15s ease;
	}

	.tag:hover {
		color: var(--accent);
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	/* Play callout */
	.play {
		margin-top: 40px;
	}

	.play__card {
		display: flex;
		align-items: center;
		gap: 18px;
		max-width: 560px;
		margin: 0 auto;
		padding: 20px 22px;
		text-decoration: none;
		color: var(--text);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 18px;
		box-shadow: var(--shadow);
		transition: transform 0.18s ease, border-color 0.18s ease;
	}

	.play__card:hover {
		transform: translateY(-4px);
		border-color: var(--accent);
	}

	.play__badge {
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 46px;
		height: 46px;
		border-radius: 12px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
	}

	.play__text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.play__label {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.play__title {
		font-size: 1.1rem;
		font-weight: 700;
	}

	.play__desc {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	.play__arrow {
		flex: none;
		margin-left: auto;
		color: var(--text-muted);
		transition: transform 0.18s ease, color 0.18s ease;
	}

	.play__card:hover .play__arrow {
		color: var(--accent);
		transform: translateX(3px);
	}

	/* Footer */
	.footer {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		margin-top: 72px;
		padding-top: 24px;
		border-top: 1px solid var(--border);
		font-size: 0.875rem;
		color: var(--text-muted);
	}

	.footer__sep {
		opacity: 0.6;
	}

	@media (max-width: 760px) {
		main {
			padding-top: 48px;
		}

		.hero {
			grid-template-columns: 1fr;
			gap: 32px;
			text-align: center;
		}

		.lede {
			margin-left: auto;
			margin-right: auto;
		}

		.actions,
		.socials {
			justify-content: center;
		}

		.hero__avatar {
			order: -1;
		}

		.avatar {
			width: 128px;
			height: 128px;
			font-size: 42px;
		}

		.focus {
			grid-template-columns: 1fr;
			margin-top: 44px;
		}
	}
</style>
